# =============================================================================
# CAPTAIN RACCOON — ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values.
# In production, all values are injected by Doppler (never commit .env!)
# =============================================================================

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO
DEBUG=false

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...     # https://console.anthropic.com
CLAUDE_MODEL=claude-opus-4-5
CLAUDE_FALLBACK_MODEL=claude-haiku-4-5

# ── Replicate (Image + Video Generation) ──────────────────────────────────────
# Sign up: https://replicate.com → API tokens
REPLICATE_API_TOKEN=r8_...

# ── HuggingFace (Free tier fallback) ─────────────────────────────────────────
# Sign up: https://huggingface.co → Settings → Access Tokens
HUGGINGFACE_API_TOKEN=hf_...

# ── Azure (TTS Voice + Blob Storage) ─────────────────────────────────────────
# Sign up via GitHub Student Pack → Azure portal
# TTS: Create "Speech" resource → Keys and Endpoint
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=eastus      # e.g. eastus, westeurope
AZURE_TTS_VOICE=en-US-GuyNeural
AZURE_TTS_STYLE=cheerful
# Storage: Create "Storage Account" → Access keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER=captain-raccoon-assets

# ── DigitalOcean Spaces (Fallback Storage) ─────────────────────────────────────
# Sign up via GitHub Student Pack → Spaces → Access Keys
DO_SPACES_KEY=your_do_spaces_key
DO_SPACES_SECRET=your_do_spaces_secret
DO_SPACES_BUCKET=captain-raccoon
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Sign up: https://www.mongodb.com/atlas → Create cluster (M0 free)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DATABASE=captain_raccoon

# ── YouTube Data API ─────────────────────────────────────────────────────────
# Google Cloud Console → Create OAuth2 credentials → YouTube Data API v3
# Then run: python scripts/setup_youtube_oauth.py
YOUTUBE_CLIENT_ID=your_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-...
YOUTUBE_REFRESH_TOKEN=your_refresh_token
YOUTUBE_CHANNEL_ID=UC...

# ── Instagram Graph API ───────────────────────────────────────────────────────
# Meta Developers → Create App → Instagram Basic Display / Graph API
INSTAGRAM_ACCESS_TOKEN=EAABsbCS...
INSTAGRAM_ACCOUNT_ID=17841...

# ── Monitoring ────────────────────────────────────────────────────────────────
# Sentry: https://sentry.io → New Project → Python
SENTRY_DSN=https://...@sentry.io/...

# Datadog: Already have Pro account from GitHub Student Pack
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key
DD_AGENT_HOST=localhost

# New Relic: GitHub Student Pack → Account creation
NEW_RELIC_LICENSE_KEY=your_newrelic_key

# ── Local Fallback URLs (if running locally with GPU) ─────────────────────────
AUTOMATIC1111_URL=http://localhost:7860
COMFYUI_URL=http://localhost:8188

# ── Pipeline Behaviour ────────────────────────────────────────────────────────
MAX_CONCURRENT_IMAGE_JOBS=3
MAX_CONCURRENT_VIDEO_JOBS=2
