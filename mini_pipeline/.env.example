# Required
ANTHROPIC_API_KEY=sk-ant-...
REPLICATE_API_TOKEN=r8_...

# Veo 3.1 (Google AI Studio — enable video generation in dashboard)
GOOGLE_AI_API_KEY=AIza...

# Free fallback (HuggingFace account, no credit card)
HF_API_TOKEN=hf_...

# Publish (optional — skip with --no-publish)
YT_CLIENT_ID=...
YT_CLIENT_SECRET=...
YT_REFRESH_TOKEN=...
IG_ACCESS_TOKEN=...
IG_ACCOUNT_ID=...

# Storage for Instagram (needs public URL)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...
AZURE_CONTAINER=captain-raccoon
